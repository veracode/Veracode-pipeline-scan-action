# dotenv-linter=""off IncorrectDelimiter

# Do not commit your actual .env file to Git! This may contain secrets or other
# private information.

# Enable/disable step debug logging (default="" `false`). For local debugging, it
# may be useful to set it to `true`.
ACTIONS_STEP_DEBUG=true

# GitHub Actions inputs should follow `INPUT_<name>` format (case-sensitive).
# Hyphens should not be converted to underscores!
INPUT_VID=""
INPUT_VKEY=""
INPUT_FILE=""
INPUT_TOKEN=""
INPUT_VERACODE_POLICY_NAME=""
INPUT_REQUEST_POLICY=""
INPUT_FAIL_ON_SEVERITY=""   
INPUT_FAIL_ON_CWE=""
INPUT_BASELINE_FILE=""
INPUT_POLICY_NAME=""
INPUT_POLICY_FILE=""
INPUT_TIMEOUT=""
INPUT_ISSUE_DETAILS=""
INPUT_SUMMARY_DISPLAY=""
INPUT_JSON_DISPLAY=""
INPUT_VERBOSE=""
INPUT_SUMMARY_OUTPUT=""
INPUT_SUMMARY_OUTPUT_FILE=""
INPUT_JSON_OUTPUT=""
INPUT_JSON_OUTPUT_FILE=""
INPUT_FILTERED_JSON_OUTPUT_FILE=""
INPUT_PROJECT_NAME=""
INPUT_PROJECT_URL=""
INPUT_PROJECT_REF=""
INPUT_APP_ID=""
INPUT_DEVELOPMENT_STAGE=""
INPUT_DEBUG=""
INPUT_STORE_BASELINE_FILE=""
INPUT_STORE_BASELINE_FILE_BRANCH=""
INPUT_CREATE_BASELINE_FROM=""
INPUT_FAIL_BUILD=""
INPUT_INCLUDE="" 
INPUT_ARTIFACT_NAME=""
INPUT_WORKFLOW_APP=""
INPUT_PLATFORMTYPE=""

# GitHub Action for artifact environmental variables needed for development and testing.
LOCAL_ACTION_WORKSPACE="" # __local_action__workspace__ Directory
LOCAL_ACTION_ARTIFACT_PATH="" #__local_action_artifact_path__ Directory

